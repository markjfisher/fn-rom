REM filename: mkglob
REM convert screen DATA statements to file "GDATA"

CLS
PRINT "Converting data to binary file..."

FH=OPENOUT("GDATA")
RESTORE 20000
FOR I%=0 TO 999
  READ D%
  BPUT# FH,D%
NEXT
CLOSE# FH
PRINT "Finished writing"

END

